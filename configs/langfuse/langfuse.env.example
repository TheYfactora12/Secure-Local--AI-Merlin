# Optional local-only Langfuse observability profile.
# Do not commit a populated config file. Copy needed values into .env.
# Generate values locally, for example:
#   openssl rand -hex 32

LANGFUSE_BIND=127.0.0.1
LANGFUSE_PORT=3010
LANGFUSE_WORKER_BIND=127.0.0.1
LANGFUSE_WORKER_PORT=3030
LANGFUSE_TELEMETRY_ENABLED=false

LANGFUSE_SALT=change-me
LANGFUSE_ENCRYPTION_KEY=change-me
LANGFUSE_NEXTAUTH_SECRET=change-me

LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_PASSWORD=change-me
LANGFUSE_POSTGRES_DB=langfuse

LANGFUSE_CLICKHOUSE_USER=langfuse
LANGFUSE_CLICKHOUSE_PASSWORD=change-me

LANGFUSE_REDIS_AUTH=change-me

LANGFUSE_MINIO_ROOT_USER=langfuse
LANGFUSE_MINIO_ROOT_PASSWORD=change-me
LANGFUSE_S3_BUCKET=langfuse
