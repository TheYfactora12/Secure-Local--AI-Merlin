#!/bin/bash
# ============================================================
# wizard — Wizard AI Stack CLI
# Usage: wizard <command> [args]
# ============================================================
WIZARD_DIR="$HOME/wizard-ai"
CYAN='\033[0;36m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'; NC='\033[0m'; BOLD='\033[1m'

n8n_url="http://localhost:5678"
brain_url="http://localhost:11434"
memory_url="http://localhost:6333"

usage() {
cat << 'EOF'
  WIZARD CLI v4

  Stack control:
    wizard start              Start Wizard stack
    wizard stop               Stop Wizard stack
    wizard restart            Restart Wizard stack
    wizard status             Show health of all services

  Brain:
    wizard ask "question"     Ask Wizard a question (local Mistral)
    wizard route "task"       Send task through smart router (n8n)
    wizard models             List loaded models
    wizard pull <model>       Pull a new model into Wizard's brain

  Memory:
    wizard ingest "title" "content"   Teach Wizard a document
    wizard collections                List Qdrant collections
    wizard memory-stats               Show memory usage

  Training:
    wizard train "prompt" "response"  Capture exchange for training

  Backup & restore:
    wizard backup             Backup Qdrant + n8n data to ~/wizard-backups
    wizard restore <file>     Restore from backup file

  Info:
    wizard help               Show this help
    wizard open               Open all UIs in browser
    wizard logs               Tail stack logs
EOF
}

require_running() {
  docker inspect wizard-brain &>/dev/null || { echo -e "${RED}Wizard is not running. Run: wizard start${NC}"; exit 1; }
}

case "$1" in

  start)
    cd "$WIZARD_DIR" && docker compose up -d
    echo -e "${GREEN}✓ Wizard is awake${NC}"
    ;;

  stop)
    cd "$WIZARD_DIR" && docker compose down
    echo -e "${YELLOW}Wizard is asleep.${NC}"
    ;;

  restart)
    cd "$WIZARD_DIR" && docker compose restart
    echo -e "${GREEN}✓ Wizard restarted${NC}"
    ;;

  status)
    echo ""
    echo -e "${BOLD}  WIZARD Stack Status${NC}"
    echo "  ───────────────────────────────────"
    for svc in wizard-brain wizard-chat wizard-memory wizard-automation wizard-dashboard; do
      ST=$(docker inspect --format='{{.State.Status}}' "$svc" 2>/dev/null || echo "not found")
      [[ "$ST" == "running" ]] \
        && echo -e "  ${GREEN}✓${NC} $svc" \
        || echo -e "  ${RED}✗${NC} $svc ($ST)"
    done
    echo ""
    echo "  Chat:       http://localhost:3001"
    echo "  Automation: http://localhost:5678"
    echo "  Memory:     http://localhost:6333/dashboard"
    echo "  Dashboard:  http://localhost:8888"
    echo ""
    ;;

  ask)
    require_running
    [[ -z "$2" ]] && { echo "Usage: wizard ask \"your question\""; exit 1; }
    echo -e "${CYAN}Wizard is thinking...${NC}"
    RESP=$(curl -s -X POST "$brain_url/api/generate" \
      -H "Content-Type: application/json" \
      -d "{\"model\":\"mistral\",\"prompt\":\"$2\",\"stream\":false}" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('response',''))")
    echo ""
    echo -e "${BOLD}Wizard:${NC} $RESP"
    echo ""
    ;;

  route)
    require_running
    [[ -z "$2" ]] && { echo "Usage: wizard route \"your task\""; exit 1; }
    echo -e "${CYAN}Routing through Wizard...${NC}"
    curl -s -X POST "$n8n_url/webhook/wizard-task" \
      -H "Content-Type: application/json" \
      -d "{\"task\":\"$2\"}" | python3 -m json.tool
    ;;

  models)
    require_running
    echo -e "${BOLD}  Models in Wizard's brain:${NC}"
    docker exec wizard-brain ollama list
    ;;

  pull)
    require_running
    [[ -z "$2" ]] && { echo "Usage: wizard pull <model-name>"; exit 1; }
    docker exec wizard-brain ollama pull "$2"
    echo -e "${GREEN}✓ $2 added to Wizard${NC}"
    ;;

  ingest)
    require_running
    [[ -z "$3" ]] && { echo "Usage: wizard ingest \"title\" \"content\""; exit 1; }
    curl -s -X POST "$n8n_url/webhook/ingest-doc" \
      -H "Content-Type: application/json" \
      -d "{\"title\":\"$2\",\"content\":\"$3\",\"collection\":\"documents\"}" | python3 -m json.tool
    ;;

  collections)
    require_running
    curl -s "$memory_url/collections" | python3 -m json.tool
    ;;

  memory-stats)
    require_running
    echo -e "${BOLD}  Wizard Memory Collections:${NC}"
    for col in conversations documents; do
      COUNT=$(curl -s "$memory_url/collections/$col" 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('result',{}).get('points_count','?'))" 2>/dev/null || echo "?")
      echo "  $col: $COUNT points"
    done
    ;;

  train)
    require_running
    [[ -z "$3" ]] && { echo "Usage: wizard train \"prompt\" \"response\""; exit 1; }
    curl -s -X POST "$n8n_url/webhook/capture-training" \
      -H "Content-Type: application/json" \
      -d "{\"prompt\":\"$2\",\"response\":\"$3\",\"source\":\"cli\"}" | python3 -m json.tool
    ;;

  backup)
    bash "$WIZARD_DIR/backup/backup.sh"
    ;;

  restore)
    [[ -z "$2" ]] && { echo "Usage: wizard restore <backup-file.tar.gz>"; exit 1; }
    bash "$WIZARD_DIR/backup/restore.sh" "$2"
    ;;

  open)
    open http://localhost:3001
    open http://localhost:5678
    open http://localhost:6333/dashboard
    open http://localhost:8888
    ;;

  logs)
    cd "$WIZARD_DIR" && docker compose logs -f --tail=50
    ;;

  help|--help|-h|"")
    usage
    ;;

  *)
    echo -e "${RED}Unknown command: $1${NC}"
    usage
    exit 1
    ;;
esac
