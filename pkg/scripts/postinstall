#!/usr/bin/env bash
# =============================================================================
# postinstall — Runs AFTER files are copied by macOS Installer.app
# Runs as root. Sets up the stack silently.
#
# Steps:
#   1. Fix file ownership (root → installing user)
#   2. Install Homebrew if missing (as the user, not root)
#   3. Run install.sh in background as the installing user
#   4. Install launchd agents for auto-start
#   5. Print instructions to /tmp/homeai-install.log
# =============================================================================
set -euo pipefail

INSTALL_DIR="/usr/local/home-ai-elite"
LOG_FILE="/tmp/homeai-install.log"

log() { echo "[postinstall] $*" | tee -a "$LOG_FILE"; }

# ---------------------------------------------------------------------------
# Detect the installing user (not root)
# ---------------------------------------------------------------------------
INSTALLING_USER=$(stat -f '%Su' /dev/console 2>/dev/null || echo "$USER")
INSTALLING_HOME=$(dscl . -read "/Users/${INSTALLING_USER}" NFSHomeDirectory 2>/dev/null \
  | awk '{print $2}' || echo "/Users/${INSTALLING_USER}")

log "Installing for user: $INSTALLING_USER ($INSTALLING_HOME)"

# The user-level install and launchd setup append to this log through `su`.
# The package script creates it as root first, so hand ownership to the user
# before those commands run.
touch "$LOG_FILE"
chown "${INSTALLING_USER}:staff" "$LOG_FILE" 2>/dev/null || true
chmod 664 "$LOG_FILE" 2>/dev/null || true
log "  ✅ Install log writable by $INSTALLING_USER"

# ---------------------------------------------------------------------------
# 1. Fix ownership: installer runs as root, files should belong to user
# ---------------------------------------------------------------------------
chown -R "${INSTALLING_USER}:staff" "$INSTALL_DIR" 2>/dev/null || true
log "  ✅ Ownership set to $INSTALLING_USER"

# ---------------------------------------------------------------------------
# 2. Copy install dir to user home (so it's writable for git)
# ---------------------------------------------------------------------------
USER_INSTALL_DIR="${INSTALLING_HOME}/home-ai-elite"
if [[ ! -d "$USER_INSTALL_DIR" ]]; then
  cp -R "$INSTALL_DIR" "$USER_INSTALL_DIR"
  chown -R "${INSTALLING_USER}:staff" "$USER_INSTALL_DIR"
  log "  ✅ Copied to: $USER_INSTALL_DIR"
else
  log "  Already exists: $USER_INSTALL_DIR (skipping copy)"
fi

# ---------------------------------------------------------------------------
# 3. Create .env from .env.example if not already present
# ---------------------------------------------------------------------------
if [[ ! -f "${USER_INSTALL_DIR}/.env" ]]; then
  cp "${USER_INSTALL_DIR}/.env.example" "${USER_INSTALL_DIR}/.env"
  chown "${INSTALLING_USER}:staff" "${USER_INSTALL_DIR}/.env"
  log "  ✅ .env created from .env.example"
fi

# ---------------------------------------------------------------------------
# 4. Make Docker Desktop CLI available even when cask binary linking was skipped
# ---------------------------------------------------------------------------
DOCKER_APP_CLI="/Applications/Docker.app/Contents/Resources/bin"
if [[ -x "${DOCKER_APP_CLI}/docker" ]]; then
  log "  ✅ Docker CLI available at ${DOCKER_APP_CLI}/docker"
else
  log "  ⚠ Docker CLI missing. Install Docker Desktop, then run: cd ~/home-ai-elite && bash install.sh"
fi

# ---------------------------------------------------------------------------
# 5. Launch Docker Desktop for first-run setup
# ---------------------------------------------------------------------------
if [[ -d "/Applications/Docker.app" ]]; then
  log "  Opening Docker Desktop for first-run setup..."
  su - "$INSTALLING_USER" -c "open -a Docker" >> "$LOG_FILE" 2>&1 || true
fi

# ---------------------------------------------------------------------------
# 6. Run install.sh as the user (background, logged)
# ---------------------------------------------------------------------------
log "  Launching non-interactive install.sh as $INSTALLING_USER (background)..."
su - "$INSTALLING_USER" -c \
  "cd '${USER_INSTALL_DIR}' && PATH='${DOCKER_APP_CLI}':\$PATH HOME_AI_NON_INTERACTIVE=true HOME_AI_SKIP_MODEL_PULLS=true bash install.sh --profile core --skip-model-pulls --non-interactive >> '${LOG_FILE}' 2>&1" &

# ---------------------------------------------------------------------------
# 7. Install launchd agents for auto-start
# ---------------------------------------------------------------------------
log "  Installing launchd auto-start agents..."
su - "$INSTALLING_USER" -c \
  "bash '${USER_INSTALL_DIR}/launchd/install-launchd.sh' >> '${LOG_FILE}' 2>&1" || true

# ---------------------------------------------------------------------------
# 8. Write post-install instructions
# ---------------------------------------------------------------------------
cat > "${INSTALLING_HOME}/Desktop/home-ai-elite-next-steps.txt" << 'INSTRUCTIONS'
┌────────────────────────────────────────────────┐
│  home-ai-elite — Installation Complete!    │
│                                            │
│  NEXT STEPS:                               │
│                                            │
│  1. Open Docker Desktop and finish setup   │
│  2. Open Terminal                          │
│  3. cd ~/home-ai-elite                     │
│  4. bash scripts/doctor.sh                 │
│  5. bash tests/core-live-smoke.sh          │
│  6. Optional: bash scripts/add-model.sh    │
│     qwen2.5:7b                             │
│                                            │
│  CORE SERVICES:                            │
│   Open WebUI  → http://localhost:3000      │
│   LiteLLM     → http://localhost:4000      │
│   Qdrant      → http://localhost:6333      │
│   Dashboard   → http://localhost:8888      │
│                                            │
│  OPTIONAL PROFILES:                        │
│   wizard start search                      │
│   wizard start automation                  │
│   wizard start coding                      │
│                                            │
│  Install log: /tmp/homeai-install.log      │
│  Uninstall:   bash ~/home-ai-elite/        │
│              pkg/scripts/uninstall.sh     │
└────────────────────────────────────────────────┘
INSTRUCTIONS

chown "${INSTALLING_USER}:staff" \
  "${INSTALLING_HOME}/Desktop/home-ai-elite-next-steps.txt" 2>/dev/null || true

log "  ✅ Next-steps file written to Desktop"
log "  ✅ postinstall complete. Full log: $LOG_FILE"
exit 0
