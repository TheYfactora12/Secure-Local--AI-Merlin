# ═══════════════════════════════════════════════════════════════════
# HOME AI ELITE — Environment Variables Template
# ───────────────────────────────────────────────────────────────────
# DO NOT use this file directly. Run install.sh — it copies this to
# .env and auto-rotates all secrets for you.
#
# If you are editing .env manually:
#   ⚠  WEBUI_SECRET_KEY, LITELLM_MASTER_KEY, N8N_PASSWORD, and
#      SEARXNG_SECRET_KEY MUST be changed from the defaults below
#      before starting any service on a networked machine.
#
#   Generate a safe value:  openssl rand -hex 32
#
# All cloud API keys are OPTIONAL — stack runs 100% locally without them.
# ═══════════════════════════════════════════════════════════════════

# ── Required Secrets ─────────────────────────────────────────────────
# ⛔ INSECURE DEFAULTS — auto-rotated by install.sh
# If you are NOT using install.sh, replace every value below with:
#   openssl rand -hex 32

# Open WebUI session signing key
WEBUI_SECRET_KEY=change-me-run-openssl-rand-hex-32

# LiteLLM master key — all services authenticate to the model router with this
LITELLM_MASTER_KEY=change-me-run-openssl-rand-hex-32

# ── n8n Auth ──────────────────────────────────────────────────────────
N8N_USER=admin
# ⛔ INSECURE DEFAULT — change before first login
N8N_PASSWORD=change-me-run-openssl-rand-hex-32
N8N_ENCRYPTION_KEY=change-me-run-openssl-rand-hex-32

# Optional n8n API key used by bootstrap workflow import.
N8N_API_KEY=

# ── SearXNG ───────────────────────────────────────────────────────────
# Required for SearXNG to boot securely — ⛔ INSECURE DEFAULT
SEARXNG_SECRET_KEY=change-me-run-openssl-rand-hex-32

# ── Timezone ──────────────────────────────────────────────────────────
# Change to your local timezone (e.g. America/Los_Angeles, Europe/London)
TZ=America/New_York

# ── AI Model Selection ────────────────────────────────────────────────
# Auto-set by install.sh based on detected RAM — override here if needed
OLLAMA_BASE_URL=http://host.docker.internal:11434
OPENHANDS_MODEL=ollama/qwen2.5-coder:14b
PERPLEXICA_CHAT_MODEL=qwen2.5:32b
QDRANT_URL=http://qdrant:6333

# Open WebUI signup control — set false after creating the admin account
ENABLE_SIGNUP=true

# ── Cloud API Keys (ALL OPTIONAL) ────────────────────────────────────
# Leave blank — stack runs 100% locally without these.
# install.sh will prompt you interactively for these.
# Add only if you want cloud model fallback for hard tasks.

# OpenAI — GPT-4o fallback        → https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — Claude fallback     → https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Perplexity — Sonar search       → https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# GitHub — OpenHands + MCP        → https://github.com/settings/tokens
# Required scopes: repo, read:org
GITHUB_TOKEN=

# ── Port Overrides (uncomment to change defaults) ─────────────────────
# OPEN_WEBUI_PORT=3000
# PERPLEXICA_BACKEND_PORT=3001
# PERPLEXICA_FRONTEND_PORT=3002
# OPENHANDS_PORT=3003
# SEARXNG_PORT=8080
# LITELLM_PORT=4000
# N8N_PORT=5678
# QDRANT_REST_PORT=6333
# QDRANT_GRPC_PORT=6334
# OLLAMA_PORT=11434
