# Home AI Elite — environment variables
# Copy to .env and fill in your values
# Never commit .env to version control

# Cloud API keys (all optional — leave blank for local-only mode)
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=

# n8n security — generate strong random strings
N8N_ENCRYPTION_KEY=
N8N_USER_MANAGEMENT_JWT_SECRET=

# Qdrant memory collection name
QDRANT_COLLECTION=home_ai_memory

# Default Ollama models
DEFAULT_LOCAL_MODEL=qwen3:32b
DEFAULT_CODER_MODEL=qwen3-coder
DEFAULT_EMBED_MODEL=nomic-embed-text

# Install settings
INSTALL_PROFILE=standard
ENABLE_OPENHANDS=no
