# ═══════════════════════════════════════════════════════════════════
# HOME AI ELITE — Environment Variables
# Copy to .env: cp .env.example .env
# All cloud API keys are OPTIONAL — stack runs 100% locally without them
# ═══════════════════════════════════════════════════════════════════

# ── Required ─────────────────────────────────────────────────────────
# Auto-generated by install.sh — change to a custom random string
WEBUI_SECRET_KEY=change-me-in-env

# LiteLLM master key — used by all services to authenticate to the router
# Change before exposing to any external network
LITELLM_MASTER_KEY=sk-home-ai-elite

# ── n8n Auth ──────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=changeme

# ── AI Model Selection ────────────────────────────────────────────────
# Auto-set by install.sh based on detected RAM — override here if needed
# Options: ollama/mistral:7b | ollama/qwen2.5:7b | ollama/qwen2.5-coder:14b
OPENHANDS_MODEL=ollama/qwen2.5-coder:14b
PERPLEXICA_CHAT_MODEL=qwen2.5:32b

# ── Cloud API Keys (ALL OPTIONAL) ────────────────────────────────────
# Leave blank — stack runs 100% locally without these
# Add only if you want cloud escalation for hard tasks

# OpenAI — for GPT-4o fallback
OPENAI_API_KEY=

# Anthropic — for Claude fallback
ANTHROPIC_API_KEY=

# Perplexity — for sonar search fallback
PERPLEXITY_API_KEY=

# GitHub — for OpenHands repo access + MCP
GITHUB_TOKEN=

# ── Port Overrides (uncomment to change defaults) ─────────────────────
# OPEN_WEBUI_PORT=3000
# PERPLEXICA_BACKEND_PORT=3001
# PERPLEXICA_FRONTEND_PORT=3002
# OPENHANDS_PORT=3003
# SEARXNG_PORT=8080
# LITELLM_PORT=4000
# N8N_PORT=5678
# QDRANT_REST_PORT=6333
# QDRANT_GRPC_PORT=6334
# OLLAMA_PORT=11434
